{
  "title": "SRE Observability - SLO Dashboard",
  "uid": "slo-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(app_requests_total[1m])",
        "legendFormat": "req/s"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 * rate(app_errors_total[5m]) / rate(app_requests_total[5m])",
        "legendFormat": "Error %"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "p95 Latency (seconds)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(app_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "s"
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "SLO Error Budget Remaining (30d window)",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 - (100 * rate(app_errors_total[30m]) / rate(app_requests_total[30m]))",
        "legendFormat": "Budget %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Request Rate over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(app_requests_total[1m])",
        "legendFormat": "{{endpoint}} {{status}}"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Latency Percentiles over time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(app_request_latency_seconds_bucket[2m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(app_request_latency_seconds_bucket[2m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(app_request_latency_seconds_bucket[2m]))",
          "legendFormat": "p99"
        }
      ],
      "datasource": "Prometheus"
    }
  ],
  "time": { "from": "now-30m", "to": "now" }
}